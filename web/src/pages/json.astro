---
import Title from "@/components/Title.astro"
import TJson from "@/components/tsx/TJson"
import Layout from "@/layouts/Layout.astro"
import { getTool } from "@/lib/tools"

const tool = getTool(new URL(Astro.request.url).pathname)
---

<Layout tool={tool}>
  <div class="small-container">{tool && <Title tool={tool} />}</div>
  <TJson client:load />
</Layout>
